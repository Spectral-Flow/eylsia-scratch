{
  "name": "server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts --watch",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/bun": "latest",
    "@types/ws": "^8.5.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/swagger": "^1.3.1",
    "elysia": "^1.3.18",
    "elevenlabs": "^0.8.1",
    "ws": "^8.16.0"
  }
}
