{
  "name": "elysia-scratch-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Elysia+Bun server with REST and WebSocket endpoints",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist",
    "start": "bun run src/index.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "elysia": "^1.1.26",
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/bearer": "^1.1.2",
    "@elysiajs/swagger": "^1.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}